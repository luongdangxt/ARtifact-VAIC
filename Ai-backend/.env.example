# FPT Cloud Marketplace
FPT_API_KEY=key_fpt_cloud_marketplace_cua_ban
FPT_ASR_URL=https://mkp-api.fptcloud.com/v1/audio/transcriptions
FPT_STT_MODEL=FPT.AI-whisper-large-v3-turbo
FPT_STT_LANGUAGE=vi
FPT_TTS_URL=https://mkp-api.fptcloud.com/v1/audio/speech
FPT_TTS_MODEL=FPT.AI-VITs
FPT_TTS_VOICE=std_leminh
FPT_TTS_FORMAT=wav
TTS_AUTOPLAY=true
AUDIO_RECORD_SECONDS=6
AUDIO_SAMPLE_RATE=16000

# Local behavior
AUTO_INGEST_ON_STARTUP=false
VECTOR_STORE_PATH=data/vector_store/chroma
VECTOR_COLLECTION_NAME=heritage_chunks

# Retrieval
TOP_K=5
MIN_RETRIEVAL_SCORE=0.04
MIN_RELEVANCE_RATIO=0.70
CHUNK_SIZE_WORDS=260
CHUNK_OVERLAP_WORDS=60
REQUIRE_HERITAGE_TOPIC=true

# LLM
# local | openai_compatible | fpt_cloud
LLM_PROVIDER=fpt_cloud
LLM_API_BASE=https://mkp-api.fptcloud.com/v1
LLM_API_KEY=
LLM_MODEL=SaoLa3.1-medium
LLM_TEMPERATURE=0.25
LLM_MAX_TOKENS=700
LLM_STREAM=true
API_AUTH_TOKEN=
API_MAX_AUDIO_BYTES=26214400
