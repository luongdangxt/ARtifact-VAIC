# Copy sang .env.local và điền giá trị thật.

# URL công khai của site (dùng cho fetch tuyệt đối phía server, OG, QR...).
# Dev: http://localhost:3000 . Prod: domain Vercel/Netlify.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Backend AI (FastAPI trong Ai-backend). Các route /api/ai* proxy tới đây (server-only,
# KHÔNG prefix NEXT_PUBLIC_). Local: http://localhost:8000 . Prod: URL public có HTTPS.
API_BASE_URL=http://localhost:8000

# Chỉ đặt nếu backend bật API_AUTH_TOKEN (gửi kèm Authorization: Bearer). Bỏ trống nếu không dùng.
# API_AUTH_TOKEN=
